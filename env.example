# Environment Variables Template
# Copy this file to .env.local and fill in the values

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Google Gemini AI ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
# Create a free Redis database at https://upstash.com
# Without these, rate limiting falls back to in-memory (resets on each deploy)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── WhatsApp Notifications (Twilio) ──────────────────────────────────────────
# Required to send real WhatsApp messages (maintenance-ready, new-order alerts)
# Without these, the app uses a stub that only logs to the console
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Sandbox: "whatsapp:+14155238886" | Production: your approved WhatsApp number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── CORS / Webhooks ───────────────────────────────────────────────────────────
# Optional: extra origin allowed to call /api/vouchers/create
WEBHOOK_ORIGIN=https://your-webhook-origin.com

# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your_pixel_id
